<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zakat Gold & Wealth Pro</title>
    <style>
        :root {
            --gold-gradient: linear-gradient(135deg, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
            --dark-bg: #0f1215;
            --card-bg: rgba(255, 255, 255, 0.05);
            --accent-gold: #d4af37;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--dark-bg);
            color: white;
            display: flex;
            justify-content: center;
            padding: 20px;
            margin: 0;
        }

        .app-container {
            width: 100%;
            max-width: 400px;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 30px;
            padding: 25px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        h1 {
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 24px;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .section-label {
            color: var(--accent-gold);
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 10px;
            display: block;
            letter-spacing: 1px;
        }

        .input-group {
            background: var(--card-bg);
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid rgba(212, 175, 55, 0.1);
        }

        label { display: block; font-size: 14px; margin-bottom: 5px; opacity: 0.8; }

        input, select {
            width: 100%;
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 12px;
            border-radius: 10px;
            color: white;
            font-size: 16px;
            box-sizing: border-box;
            outline: none;
            margin-bottom: 10px;
        }

        input:focus { border-color: var(--accent-gold); }

        .btn-calculate {
            width: 100%;
            background: var(--gold-gradient);
            border: none;
            padding: 15px;
            border-radius: 15px;
            color: #000;
            font-weight: bold;
            font-size: 18px;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 15px rgba(179, 135, 40, 0.3);
        }

        .btn-calculate:active { transform: scale(0.98); }

        .result-card {
            margin-top: 25px;
            background: linear-gradient(145deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
            border-radius: 20px;
            padding: 20px;
            text-align: center;
            display: none;
            border: 1px solid rgba(212, 175, 55, 0.3);
        }

        .zakat-value {
            font-size: 32px;
            font-weight: bold;
            color: #fff;
            text-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
            margin: 10px 0;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            margin-bottom: 5px;
            opacity: 0.7;
        }
    </style>
</head>
<body>

<div class="app-container">
    <div class="header">
        <h1>Zakat Pro</h1>
        <p style="font-size: 12px; opacity: 0.5;">Gold, Silver & Wealth Calculator</p>
    </div>

    <!-- Live Market Rates -->
    <span class="section-label">Market Rates (Manual Entry)</span>
    <div class="input-group">
        <label>Gold Price (per gram 24K)</label>
        <input type="number" id="goldPrice" placeholder="e.g. 75.00">
        <label>Silver Price (per gram)</label>
        <input type="number" id="silverPrice" placeholder="e.g. 0.90">
    </div>

    <!-- Assets -->
    <span class="section-label">Your Assets</span>
    <div class="input-group">
        <label>Gold Weight (grams)</label>
        <div style="display: flex; gap: 10px;">
            <input type="number" id="goldWeight" placeholder="Weight" style="flex: 2;">
            <select id="goldKarat" style="flex: 1;">
                <option value="24">24K</option>
                <option value="22">22K</option>
                <option value="21">21K</option>
                <option value="18">18K</option>
            </select>
        </div>

        <label>Silver Weight (grams)</label>
        <input type="number" id="silverWeight" placeholder="Total grams">

        <label>Cash / Savings (Currency)</label>
        <input type="number" id="cashAmount" placeholder="Total cash/bank">
    </div>

    <button class="btn-calculate" onclick="calculateZakat()">CALCULATE ZAKAT</button>

    <div id="resultCard" class="result-card">
        <span style="font-size: 12px; color: var(--accent-gold);">TOTAL ZAKAT DUE</span>
        <div class="zakat-value" id="zakatTotal">0.00</div>
        <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.1); margin: 15px 0;">
        <div class="detail-row"><span>Pure Gold Equiv:</span> <span id="pureGoldRes">0g</span></div>
        <div class="detail-row"><span>Total Net Value:</span> <span id="totalValueRes">$0</span></div>
    </div>
</div>

<script>
    function calculateZakat() {
        // Inputs
        const gPrice = parseFloat(document.getElementById('goldPrice').value) || 0;
        const sPrice = parseFloat(document.getElementById('silverPrice').value) || 0;
        const gWeight = parseFloat(document.getElementById('goldWeight').value) || 0;
        const gKarat = parseInt(document.getElementById('goldKarat').value);
        const sWeight = parseFloat(document.getElementById('silverWeight').value) || 0;
        const cash = parseFloat(document.getElementById('cashAmount').value) || 0;

        // Calculations
        const pureGoldWeight = (gWeight * gKarat) / 24;
        const goldValue = pureGoldWeight * gPrice;
        const silverValue = sWeight * sPrice;
        const totalNetWealth = goldValue + silverValue + cash;
        
        // Zakat (2.5%)
        const zakatDue = totalNetWealth * 0.025;

        // Update UI
        document.getElementById('resultCard').style.display = 'block';
        document.getElementById('zakatTotal').innerText = zakatDue.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
        document.getElementById('pureGoldRes').innerText = pureGoldWeight.toFixed(2) + "g";
        document.getElementById('totalValueRes').innerText = totalNetWealth.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
    }
</script>

</body>
</html>
